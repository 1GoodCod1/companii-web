# Local dev: same-origin via Vite proxy (5174 → API 4100)
VITE_API_URL=/api/v1
# VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:4100

VITE_ENV=development
VITE_USE_HTTPONLY_COOKIE=true

# Prod build (Docker/CI) — задаётся build args, не здесь:
# VITE_API_URL=https://api.companii.faber.md/api/v1
# VITE_ENV=production

# Optional
# VITE_MEDIA_URL=
# VITE_WS_URL=
